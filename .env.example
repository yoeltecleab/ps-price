PS_PRICE_DATABASE_PATH=/data/ps_price.sqlite3
PS_PRICE_STORE_LOCALE=en-us
PS_PRICE_SCHEDULER_ENABLED=true
PS_PRICE_CHECK_INTERVAL_MINUTES=360
PS_PRICE_FEED_SYNC_INTERVAL_MINUTES=60
# Comma-separated browse shards for full catalog sync (all,PS5,PS4)
PS_PRICE_CATALOG_SYNC_SHARDS=all,PS5,PS4
PS_PRICE_CACHE_TTL_SECONDS=1800
PS_PRICE_REQUEST_MIN_INTERVAL_SECONDS=3
PS_PRICE_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# SMTP is optional. Watches still persist when SMTP is not configured, but
# email notifications are logged as skipped until these settings are provided.
PS_PRICE_SMTP_HOST=
PS_PRICE_SMTP_PORT=587
PS_PRICE_SMTP_USERNAME=
PS_PRICE_SMTP_PASSWORD=
PS_PRICE_SMTP_USE_TLS=true
PS_PRICE_SMTP_USE_SSL=false
PS_PRICE_NOTIFICATION_FROM_EMAIL=ps-price@example.com
