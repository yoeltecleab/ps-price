# PostgreSQL (Docker Compose creates the DB and sets PS_PRICE_DATABASE_URL for the backend).
# Do NOT set PS_PRICE_DATABASE_URL here for Docker — compose builds it automatically.
POSTGRES_USER=psprice
POSTGRES_PASSWORD=psprice
POSTGRES_DB=psprice

# For running the backend on the host (not in Docker):
# PS_PRICE_DATABASE_URL=postgresql+psycopg://psprice:psprice@localhost:5432/psprice

PS_PRICE_STORE_LOCALE=en-us
PS_PRICE_SCHEDULER_ENABLED=true
PS_PRICE_SYNC_ON_STARTUP=true
PS_PRICE_CATALOG_REFRESH_COOLDOWN_SECONDS=60
PS_PRICE_CHECK_INTERVAL_MINUTES=360
PS_PRICE_FEED_SYNC_INTERVAL_MINUTES=60
# Comma-separated browse shards for full catalog sync (all,PS5,PS4)
PS_PRICE_CATALOG_SYNC_SHARDS=all,PS5,PS4
PS_PRICE_FRONTEND_URL=http://localhost:3000
PS_PRICE_WEBAUTHN_RP_ID=localhost
PS_PRICE_WEBAUTHN_ORIGIN=http://localhost:3000
PS_PRICE_REQUIRE_EMAIL_VERIFICATION=true
PS_PRICE_COOKIE_SECURE=false
PS_PRICE_JWT_SECRET=dev-only-change-me-use-ps-price-jwt-secret-in-prod
PS_PRICE_JWT_ACCESS_TTL_MINUTES=30
PS_PRICE_JWT_REFRESH_TTL_DAYS=30
PS_PRICE_PRODUCTION_MODE=false
PS_PRICE_ADMIN_EMAILS=you@example.com
# Shared secret between Next.js proxy and backend (min 32 chars in production).
# Generate: openssl rand -base64 48
PS_PRICE_INTERNAL_API_KEY=ps-price-local-proxy-key

PS_PRICE_CACHE_TTL_SECONDS=1800
PS_PRICE_REQUEST_MIN_INTERVAL_SECONDS=3
PS_PRICE_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# SMTP is optional. Watches still persist when SMTP is not configured, but
# email notifications are logged as skipped until these settings are provided.
PS_PRICE_SMTP_HOST=
PS_PRICE_SMTP_PORT=587
PS_PRICE_SMTP_USERNAME=
PS_PRICE_SMTP_PASSWORD=
PS_PRICE_SMTP_USE_TLS=true
PS_PRICE_SMTP_USE_SSL=false
PS_PRICE_NOTIFICATION_FROM_EMAIL=ps-price@example.com
PS_PRICE_NOTIFICATION_FROM_NAME=PS Prices
